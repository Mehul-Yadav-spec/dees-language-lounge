# ─────────────────────────────────────────────────────────────
# Dees Language Lounge — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Supabase (lead capture) — server inserts use the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp — digits only, incl. country code, no "+" (e.g. 919876543210).
# Powers the floating widget and the 'whatsapp' CTA mode / success deep-link.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics (leave blank to disable). Env-driven IDs only.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Absolute site URL used for metadata / sitemap / canonical (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://deeslanguagelounge.com
