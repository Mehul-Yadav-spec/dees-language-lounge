# ─────────────────────────────────────────────────────────────
# Dees Language Lounge — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Supabase (lead capture) — server inserts use the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp — digits only, incl. country code, no "+" (e.g. 919876543210).
# Powers the floating widget and the 'whatsapp' CTA mode / success deep-link.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics (leave blank to disable). Env-driven IDs only.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Absolute site URL used for metadata / sitemap / canonical (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://deeslanguagelounge.com

# ─── Zoom (live classes + recording pipeline) ────────────────────────────────
# Server-to-Server OAuth app (marketplace.zoom.us). Scopes: meeting:write,
# cloud_recording:read, cloud_recording:write. Secrets — server-only, never
# expose with NEXT_PUBLIC.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# The licensed teacher/host user (login email or Zoom userId) that class
# meetings are created under.
ZOOM_TEACHER_USER_ID=
# Webhook app "Secret Token" — verifies inbound recording.completed events.
ZOOM_WEBHOOK_SECRET=

# Shared secret protecting the cron + webhook-worker endpoints (any long random
# string). Vercel Cron sends it as the Authorization bearer.
CRON_SECRET=
